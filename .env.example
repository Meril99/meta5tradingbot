# =============================================================================
# telegram-mt5-bot — Environment Configuration
# Copy this file to /etc/telegram-mt5-bot/.env and fill in your values.
# =============================================================================

# Telegram TDLib (obtain from https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+352691234567
TELEGRAM_CHANNEL_ID=-1001234567890   # negative = supergroup/channel

# Telegram Bot API — for trade notifications (obtain from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_NOTIFY_CHAT_ID=123456789    # your personal chat ID with the bot

# ZeroMQ ports (internal, localhost only)
ZMQ_LISTENER_PORT=5555
ZMQ_PARSER_PORT=5556
ZMQ_EVENT_PORT=5557                  # EA sends trade events here

# Risk management
ACCOUNT_BALANCE=10000.0   # USD, demo account balance
RISK_PERCENT=1.0          # percentage of balance risked per trade
MIN_LOTS=0.01
MAX_LOTS=1.0

# Trade journal CSV (optional, defaults to /var/lib/telegram-mt5-bot/trade_journal.csv)
TRADE_JOURNAL_PATH=/var/lib/telegram-mt5-bot/trade_journal.csv

# MT5 (for reference — credentials are entered in the MT5 GUI)
MT5_SERVER=PUPrimeLtd-Demo
MT5_LOGIN=12345678
